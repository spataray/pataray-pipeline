# ═══════════════════════════════════════════
# Pataray Pipeline — SMTP Configuration
# ═══════════════════════════════════════════
# Copy this file to config.env and fill in your values.
# DO NOT commit config.env to git!
#
# For Gmail:
#   1. Enable 2-Factor Authentication on your Google account
#   2. Go to: https://myaccount.google.com/apppasswords
#   3. Create an app password for "Mail"
#   4. Use that 16-char password below (not your regular password)
#

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=spataray@gmail.com
SMTP_PASS=your-gmail-app-password-here
FROM_EMAIL=spataray@gmail.com
